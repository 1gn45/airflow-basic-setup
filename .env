# Airflow home directory on the Windows host
AIRFLOW_HOME=C:/airflow

# Airflow image version
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3

# Airflow UID (leave as 50000 for the default airflow user inside the container)
AIRFLOW_UID=50000

# Postgres credentials
# ⚠️  Change POSTGRES_PASSWORD to a strong random value before going to production.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Fernet key for encrypting sensitive data in the metadata DB.
# ⚠️  REQUIRED – generate your own key and paste it here before first run.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Webserver secret key – change before going to production.
# Generate a new one with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-before-production
